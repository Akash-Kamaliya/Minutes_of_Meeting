@model MeetingTypeModel

<div class="container pb-3">
    <h2 class="h2 fw-bold text-danger">Delete Meeting Type</h2>
</div>
@if (@TempData["SucessMessage"] != null)
{
    <div class="alert alert-primary" role="alert">
        @TempData["SucessMessage"]
    </div>
}
@if (@TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger" role="alert">
        @TempData["ErrorMessage"]
    </div>
}
<div class="card shadow rounded-4 border-danger overflow-hidden">
    <div class="table-head d-flex align-items-center px-3 py-2 bg-primary text-white">
        <div class="h5">Delete Meeting Type</div>
    </div>

    <div class="card-body">

        <ul class="list-group mb-3">
            <li class="list-group-item"><b>ID:</b> @Model.MeetingTypeID</li>
            <li class="list-group-item"><b>Name:</b> @Model.MeetingTypeName</li>
            <li class="list-group-item"><b>Remarks:</b> @Model.Remarks</li>
        </ul>

        <form asp-action="MeetingTypeDeleteConfirm" method="post">
            <input type="hidden" name="MeetingTypeID" value="@Model.MeetingTypeID" />

            <button type="submit" class="btn btn-danger">
                <i class="bi bi-trash"></i> Delete
            </button>

            <a asp-action="MeetingTypeList" class="btn btn-secondary">Cancel</a>
        </form>

    </div>
</div>
