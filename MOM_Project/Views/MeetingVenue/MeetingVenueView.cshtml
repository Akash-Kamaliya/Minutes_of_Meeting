<h2 class="h2 fw-bold">View Meeting Venue</h2>

<div class="card shadow rounded-4 overflow-hidden">
    <div class="table-head d-flex align-items-center px-3 py-2 bg-primary text-white">
        <div class="h5">View Meeting Venue</div>
    </div>
    <div class="card-body">

        <div class="row mb-3">
            <div class="col-md-3 fw-bold">Meeting Venue ID</div>
            <div class="col-md-9">@Model.MeetingVenueID</div>
        </div>

        <div class="row mb-3">
            <div class="col-md-3 fw-bold">Meeting Venue Name</div>
            <div class="col-md-9">@Model.MeetingVenueName</div>
        </div>

        <div class="row mb-3">
            <div class="col-md-3 fw-bold">Created</div>
            <div class="col-md-9">@Model.Created</div>
        </div>

        <div class="row mb-3">
            <div class="col-md-3 fw-bold">Modified</div>
            <div class="col-md-9">@Model.Modified</div>
        </div>


        <div class="d-flex justify-content-start">
            <a asp-action="MeetingVenueList" class="btn btn-primary">
                <i class="bi bi-arrow-left"></i> Back
            </a>
        </div>

    </div>
</div>
