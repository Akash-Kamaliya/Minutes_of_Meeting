@model IEnumerable<MOM_Project.Models.MeetingVenueModel>

<div class="container pb-3">
    <h2 class="h2 fw-bold">Meeting Venue</h2>
    <div class="d-flex justify-content-end">
        <a class="btn btn-primary" asp-action="MeetingVenueAdd">
            <i class="bi bi-plus"></i> Add Venue
        </a>
    </div>
</div>
@if (@TempData["SucessMessage"] != null)
{
    <div class="alert alert-primary" role="alert">
        @TempData["SucessMessage"]
    </div>
}
@if (@TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger" role="alert">
        @TempData["ErrorMessage"]
    </div>
}
<div class="shadow rounded-4 overflow-hidden">
    <div class="bg-primary text-white px-3 py-2 h5 mb-0">
        Meeting Venue List
    </div>

    @if (Model != null && Model.Any())
    {
        <table class="table main-table mb-0">
            <thead>
                <tr>
                    <th>Department Name</th>
                    <th class="text-center">Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.MeetingVenueName</td>
                        <td class="text-center">
                            <div class="action-icons">
                                <a asp-action="MeetingVenueView" asp-controller="MeetingVenue" asp-route-MeetingVenueID="@item.MeetingVenueID" title="View">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a asp-action="MeetingVenueEditForm" asp-controller="MeetingVenue" asp-route-MeetingVenueID="@item.MeetingVenueID" title="Edit">
                                    <i class="bi bi-pen"></i>
                                </a>
                                <a asp-action="MeetingVenueDeleteForm" asp-controller="MeetingVenue" asp-route-MeetingVenueID="@item.MeetingVenueID" title="Delete">
                                    <i class="bi bi-trash text-danger"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <h5>No Data Found</h5>
    }
</div>
