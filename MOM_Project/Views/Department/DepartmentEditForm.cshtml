@model DepartmentModel

<div class="container pb-3">
    <h2 class="h2 fw-bold">Edit Department</h2>
</div>
@if (@TempData["SucessMessage"] != null)
{
    <div class="alert alert-primary" role="alert">
        @TempData["SucessMessage"]
    </div>
}
@if (@TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger" role="alert">
        @TempData["ErrorMessage"]
    </div>
}
<div class="card shadow rounded-4 overflow-hidden">
    <div class="table-head d-flex align-items-center px-3 py-2 bg-primary text-white">
        <div class="h5 mb-0">Department Edit Form</div>
    </div>

    <div class="card-body">

        <form asp-action="DepartmentEditForm" method="post">


            <input type="hidden" asp-for="DepartmentID" />
            <div class="row mb-4">
                <div class="col-md-12">
                    <label asp-for="DepartmentName" class="form-label"></label>
                    <input asp-for="DepartmentName" class="form-control" />
                    <span asp-validation-for="DepartmentName" class="text-danger"></span>
                </div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-pencil"></i> Update
                </button>
                <a asp-action="DepartmentList" class="btn btn-secondary">
                    Cancel
                </a>
            </div>

        </form>

    </div>
</div>

