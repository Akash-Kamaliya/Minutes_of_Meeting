@model IEnumerable<MOM_Project.Models.DepartmentModel>

<div class="container pb-3">
    <h2 class="h2 fw-bold">Department</h2>
    <div class="d-flex justify-content-end">
        <a class="btn btn-primary" asp-action="DepartmentAdd">
            <i class="bi bi-plus"></i> Add Department
        </a>
    </div>
</div>

@if (@TempData["SucessMessage"] != null)
{
    <div class="alert alert-primary" role="alert">
        @TempData["SucessMessage"]
    </div>
}
@if (@TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger" role="alert">
        @TempData["ErrorMessage"]
    </div>
}

<form method="get" asp-action="DepartmentList" asp-controller="Department" class="mb-3">
    <div class="row g-2 align-items-end">
        <div class="col-md-4">
            <label for="SearchText" class="form-label">Search by Department Name</label>
            <input type="text"
                   name="searchText"
                   id="searchText"
                   class="form-control"
                   placeholder="Enter department name"
                   value="@ViewBag.SearchText" />
        </div>
        <div class="col-md-4">
            <button type="submit" class="btn btn-info">
                <i class="fas fa-search"></i> Search
            </button>
            <a asp-action="DepartmentList"
               asp-controller="Department"
               class="btn btn-secondary ms-2">
                <i class="fas fa-undo"></i> Reset
            </a>
        </div>
    </div>
</form>


<div class="shadow rounded-4 overflow-hidden">
    <div class="table-head d-flex align-items-center px-3 py-2 bg-primary text-white">
        <div class="h5 mb-0">Department List</div>
    </div>
    
    @if (Model != null && Model.Any())
    {
        <table class="table main-table mb-0">
            <thead>
                <tr>
                    <th>Department Name</th>
                    <th class="text-center">Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.DepartmentName</td>
                        <td class="text-center">
                            <div class="action-icons">
                                <a asp-action="DepartmentView" asp-controller="Department" asp-route-DepartmentID="@item.DepartmentID" title="View">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a asp-action="DepartmentEditForm" asp-controller="Department" asp-route-DepartmentID="@item.DepartmentID" title="Edit">
                                    <i class="bi bi-pen"></i>
                                </a>
                                <a asp-action="DepartmentDeleteForm" asp-controller="Department" asp-route-DepartmentID="@item.DepartmentID" title="Delete">
                                    <i class="bi bi-trash text-danger"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <h5>No Data Found</h5>
    }
</div>