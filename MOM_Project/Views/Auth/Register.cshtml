@model MOM_Project.Models.UserModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <title>MOM Register</title>
    <link href="~/assets/css/auth.css" rel="stylesheet" />
</head>
<body class="auth-body">

    <div class="auth-card">
        <h2>Create Account</h2>
        <p class="subtitle">Join Minutes Of Meeting</p>

        <form method="post">
            <input asp-for="FullName" placeholder="Full Name" required />
            <input asp-for="Email" placeholder="Email" required />
            <input asp-for="MobileNo" placeholder="Mobile No" />
            <input asp-for="Password" placeholder="Password" type="password" required />

            <button type="submit">Register</button>

            <p class="switch">
                Already have an account?
                <a href="/Auth/Login">Login</a>
            </p>
        </form>
    </div>

</body>
</html>
