@model MOM_Project.Models.MeetingMemberModel

<div class="container pb-3">
    <h2 class="h2 fw-bold">Edit Meeting Member</h2>
</div>

<div class="card shadow rounded-4 overflow-hidden">
    <div class="table-head d-flex align-items-center px-3 py-2 bg-primary text-white">
        <div class="h5 mb-0">Edit Meeting Member</div>
    </div>

    <div class="card-body">

        <form asp-action="MeetingMemberEditForm" method="post">

            <div class="row mb-3">
                <div class="col-md-12">
                    <label class="form-label">Meeting Name</label>
                    <input asp-for="MeetingName" class="form-control" />
                    <span asp-validation-for="MeetingName" class="text-danger"></span>
                </div>
            </div>

            <div class="row mb-3">
                <div class="col-md-6">
                    <label class="form-label">Staff Name</label>
                    <input asp-for="StaffName" class="form-control" />
                    <span asp-validation-for="StaffName" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label class="form-label">Attendance</label>
                    <select asp-for="IsPresent" class="form-select">
                        <option value="">-- Select --</option>
                        <option value="true">Present</option>
                        <option value="false">Absent</option>
                    </select>
                    <span asp-validation-for="IsPresent" class="text-danger"></span>
                </div>

                <div class="col-md-12">
                    <label class="form-label">Remarks</label>
                    <textarea asp-for="Remarks" class="form-control"></textarea>
                    <span asp-validation-for="Remarks" class="text-danger"></span>
                </div>
            </div>

            <button type="submit" class="btn btn-primary">Update</button>
            <a asp-action="MeetingMemberList" class="btn btn-secondary">Cancel</a>
        </form>
    </div>
</div>
