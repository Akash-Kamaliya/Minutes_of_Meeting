@model MOM_Project.Models.MeetingMemberModel

<div class="container pb-3">
    <h2 class="h2 fw-bold">Edit Meeting Member</h2>
</div>

<div class="card shadow rounded-4 overflow-hidden">
    <div class="table-head px-3 py-2 bg-primary text-white">
        <div class="h5">Edit Meeting Member</div>
    </div>

    <div class="card-body">

        <form asp-action="MeetingMemberEditForm" method="post">

            <input type="hidden" asp-for="MeetingMemberID" />

            <div class="mb-3">  
                <label>Meeting</label>

                <select asp-for="MeetingID" class="form-control">
                    @foreach (var meeting in ViewBag.MeetingList)
                    {
                        <option value="@meeting.MeetingID"
                                selected="@(meeting.MeetingID == Model.MeetingID)">
                            @meeting.MeetingTypeName
                        </option>
                    }
                </select>

            </div>

            <div class="mb-3">
                <label>Staff</label>

                <select asp-for="StaffID" class="form-control">
                    @foreach (var staff in ViewBag.StaffList)
                    {
                        <option value="@staff.StaffID"
                                selected="@(staff.StaffID == Model.StaffID)">
                            @staff.StaffName
                        </option>
                    }
                </select>

            </div>

            <div class="mb-3">
                <label asp-for="IsPresent"></label>
                <select asp-for="IsPresent" class="form-control">
                    <option value="true">Present</option>
                    <option value="false">Absent</option>
                </select>
            </div>

            <div class="mb-3">
                <label asp-for="Remarks"></label>
<textarea asp-for="Remarks" class="form-control"></textarea>
            </div>

            <button type="submit" class="btn btn-primary">
                Update
            </button>

            <a asp-action="MeetingMemberList" class="btn btn-secondary">
                Cancel
            </a>

        </form>

    </div>
</div>