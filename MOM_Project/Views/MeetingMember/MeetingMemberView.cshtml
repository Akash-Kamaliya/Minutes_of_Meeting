@model MOM_Project.Models.MeetingMemberModel

<div class="container py-3">

    <h2 class="fw-bold mb-4">View Meeting Member</h2>
    <div class="card shadow-lg border-0 rounded-4">

        <div class="card-header bg-primary text-white fw-semibold fs-5">
            Meeting Member Details
        </div>

        <div class="card-body">
            <div class="row g-4">

                <div class="col-md-6">
                    <label class="text-muted small mb-1">Meeting Name</label>
                    <div class="form-control bg-light">
                        @Model.MeetingTypeName
                    </div>
                </div>

                <div class="col-md-6">
                    <label class="text-muted small mb-1">Staff Name</label>
                    <div class="form-control bg-light">
                        @Model.StaffName
                    </div>
                </div>

                <div class="col-md-6">
                    <label class="text-muted small mb-1">Present</label>
                    <div class="form-control bg-light">
                        @(Model.IsPresent == true ? "Yes" : "No")
                    </div>
                </div>

                <div class="col-md-6">
                    <label class="text-muted small mb-1">Remarks</label>
                    <div class="form-control bg-light">
                        @Model.Remarks
                    </div>
                </div>

                <div class="col-md-6">
                    <label class="text-muted small mb-1">Created</label>
                    <div class="form-control bg-light">
                        @Model.Created.ToString("dd-MM-yyyy hh:mm tt")
                    </div>
                </div>

                <div class="col-md-6">
                    <label class="text-muted small mb-1">Modified</label>
                    <div class="form-control bg-light">
                        @Model.Modified.ToString("dd-MM-yyyy hh:mm tt")
                    </div>
                </div>

            </div>

            <div class="mt-4">
                <a asp-action="MeetingMemberList" class="btn btn-outline-primary">
                    <i class="bi bi-arrow-left"></i> Back to List
                </a>
            </div>
        </div>
    </div>
</div>