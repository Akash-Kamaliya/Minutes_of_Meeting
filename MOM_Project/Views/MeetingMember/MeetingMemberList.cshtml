@model IEnumerable<MOM_Project.Models.MeetingMemberModel>

<div class="container pb-3">
    <h2 class="h2 fw-bold">Meeting Member</h2>
    <div class="d-flex justify-content-end">
        <a class="btn btn-primary" asp-action="MeetingMemberAdd">
            <i class="bi bi-plus"></i> Add Meeting Member
        </a>
    </div>
</div>

@if (TempData["SucessMessage"] != null)
{
    <div class="alert alert-primary">@TempData["SucessMessage"]</div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
}

<form method="get" asp-action="MeetingMemberList" asp-controller="MeetingMember" class="mb-3">
    <div class="row g-2 align-items-end">
        <div class="col-md-4">
            <label class="form-label">Search by Meeting or Staff</label>
            <input type="text"
                   name="searchText"
                   class="form-control"
                   placeholder="Enter meeting or staff name"
                   value="@ViewBag.SearchText" />
        </div>

        <div class="col-md-4">
            <button type="submit" class="btn btn-info">
                <i class="fas fa-search"></i> Search
            </button>

            <a asp-action="MeetingMemberList"
               asp-controller="MeetingMember"
               class="btn btn-secondary ms-2">
                <i class="fas fa-undo"></i> Reset
            </a>
        </div>
    </div>
</form>

<div class="shadow rounded-4 overflow-hidden">
    <div class="table-head d-flex align-items-center px-3 py-2 bg-primary text-white">
        <div class="h5 mb-0">Meeting Member List</div>
    </div>

    @if (Model != null && Model.Any())
    {
        <table class="table main-table mb-0">
            <thead>
                <tr>
                    <th>Meeting Name</th>
                    <th>Staff Name</th>
                    <th>Present</th>
                    <th>Remarks</th>
                    <th class="text-center">Action</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.MeetingName</td>
                        <td>@item.StaffName</td>
                        <td>
                            @(item.IsPresent == true ? "Yes" : "No")
                        </td>
                        <td>@item.Remarks</td>

                        <td class="text-center">
                            <div class="action-icons">

                                <a asp-action="MeetingMemberView"
                                   asp-route-MeetingMemberID="@item.MeetingMemberID"
                                   title="View">
                                    <i class="bi bi-eye"></i>
                                </a>

                                <a asp-action="MeetingMemberEditForm"
                                   asp-route-MeetingMemberID="@item.MeetingMemberID"
                                   title="Edit">
                                    <i class="bi bi-pen"></i>
                                </a>

                                <a asp-action="MeetingMemberDeleteForm"
                                   asp-route-MeetingMemberID="@item.MeetingMemberID"
                                   title="Delete">
                                    <i class="bi bi-trash text-danger"></i>
                                </a>

                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <h5 class="p-3">No Data Found</h5>
    }
</div>