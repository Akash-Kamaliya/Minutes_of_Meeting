@model MOM_Project.Models.MeetingMemberModel

<div class="container pb-3">
    <h2 class="h2 fw-bold">Add Meeting Member</h2>
</div>

<div class="card shadow rounded-4 overflow-hidden">
    <div class="table-head px-3 py-2 bg-primary text-white">
        <div class="h5">Add Meeting Member</div>
    </div>

    <div class="card-body">

        <form asp-action="MeetingMemberAdd" method="post">

            <div class="mb-3">
                <label class="form-label">Meeting</label>
                <select asp-for="MeetingID" class="form-control">

                    <option value="">Select Meeting</option>

                    @foreach (var meeting in ViewBag.MeetingList)
                    {
                        <option value="@meeting.MeetingID">
                            @meeting.MeetingTypeName
                        </option>
                    }

                </select>
            </div>

            <div class="mb-3">
                <label class="form-label">Staff</label>

                <select asp-for="StaffID" class="form-control">

                    <option value="">Select Staff</option>

                    @foreach (var staff in ViewBag.StaffList)
                    {
                        <option value="@staff.StaffID">
                            @staff.StaffName
                        </option>
                    }

                </select>

            </div>

            <div class="mb-3">
                <label asp-for="IsPresent" class="form-label"></label>
                <select asp-for="IsPresent" class="form-control">
                    <option value="">Select</option>
                    <option value="true">Present</option>
                    <option value="false">Absent</option>
                </select>
                <span asp-validation-for="IsPresent" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Remarks" class="form-label"></label>
<textarea asp-for="Remarks" class="form-control"></textarea>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-save"></i> Save
                </button>

                <a asp-action="MeetingMemberList" class="btn btn-secondary">
                    Cancel
                </a>
            </div>

        </form>
    </div>
</div>