@model MOM_Project.Models.MeetingsModel

<div class="container py-3">

    <h2 class="fw-bold mb-4">View Meeting</h2>

    <div class="card shadow-lg border-0 rounded-4">

        <div class="card-header bg-primary text-white fw-semibold fs-5">
            Meeting Details
        </div>

        <div class="card-body">
            <div class="row g-4">
                <div class="col-md-6">
                    <label class="text-muted small mb-1">Meeting Date</label>
                    <div class="form-control bg-light">
                        @Model.MeetingDate.ToString("dd-MM-yyyy hh:mm tt")
                    </div>
                </div>

                <div class="col-md-6">
                    <label class="text-muted small mb-1">Meeting Type</label>
                    <div class="form-control bg-light">
                        @Model.MeetingTypeName
                    </div>
                </div>

                <div class="col-md-6">
                    <label class="text-muted small mb-1">Department</label>
                    <div class="form-control bg-light">
                        @Model.DepartmentName
                    </div>
                </div>

                <div class="col-md-6">
                    <label class="text-muted small mb-1">Meeting Venue</label>
                    <div class="form-control bg-light">
                        @Model.MeetingVenueName
                    </div>
                </div>

                <div class="col-md-12">
                    <label class="text-muted small mb-1">Meeting Description</label>
                    <div class="form-control bg-light">
                        @Model.MeetingDescription
                    </div>
                </div>

                <div class="col-md-6">
                    <label class="text-muted small mb-1">Created</label>
                    <div class="form-control bg-light">
                        @Model.Created.ToString("dd-MM-yyyy hh:mm tt")
                    </div>
                </div>

                <div class="col-md-6">
                    <label class="text-muted small mb-1">Modified</label>
                    <div class="form-control bg-light">
                        @Model.Modified.ToString("dd-MM-yyyy hh:mm tt")
                    </div>
                </div>

            </div>

            <div class="mt-4">
                <a asp-action="MeetingsList" class="btn btn-outline-primary">
                    <i class="bi bi-arrow-left"></i> Back to List
                </a>
            </div>
        </div>
    </div>
</div>