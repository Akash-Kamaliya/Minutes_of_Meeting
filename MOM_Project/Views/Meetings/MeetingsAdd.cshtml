@model MOM_Project.Models.MeetingsModel

<div class="container pb-3">
    <h2 class="h2 fw-bold">Add Meeting</h2>
</div>

<div class="card shadow rounded-4 overflow-hidden">

    <div class="table-head d-flex align-items-center px-3 py-2 bg-primary text-white">
        <div class="h5">Add Meeting</div>
    </div>

    <div class="card-body">

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-primary">
                @TempData["SuccessMessage"]
            </div>
        }

        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger">
                @TempData["ErrorMessage"]
            </div>
        }

        <form asp-action="MeetingsAdd" method="post">
            <div class="row">

                <div class="col-md-6 mb-3">
                    <label asp-for="MeetingDate" class="form-label"></label>
                    <input asp-for="MeetingDate" type="datetime-local" class="form-control" />
                    <span asp-validation-for="MeetingDate" class="text-danger"></span>
                </div>

                <div class="col-md-6 mb-3">
                    <label class="form-label">Meeting Type</label>

                    <select asp-for="MeetingTypeID" class="form-control">

                        <option value="">Select Meeting Type</option>

                        @foreach (var item in ViewBag.MeetingTypeList)
                        {
                            <option value="@item.MeetingTypeID">
                                @item.MeetingTypeName
                            </option>
                        }
                    </select>
                    <span asp-validation-for="MeetingTypeID" class="text-danger"></span>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label">Department</label>

                    <select asp-for="DepartmentID" class="form-control">

                        <option value="">Select Department</option>

                        @foreach (var item in ViewBag.DepartmentList)
                        {
                            <option value="@item.DepartmentID">
                                @item.DepartmentName
                            </option>
                        }

                    </select>

                    <span asp-validation-for="DepartmentID" class="text-danger"></span>
                </div>

                <div class="col-md-6 mb-3">
                    <label class="form-label">Meeting Venue</label>

                    <select asp-for="MeetingVenueID" class="form-control">

                        <option value="">Select Venue</option>

                        @foreach (var item in ViewBag.VenueList)
                        {
                            <option value="@item.MeetingVenueID">
                                @item.MeetingVenueName
                            </option>
                        }

                    </select>

                    <span asp-validation-for="MeetingVenueID" class="text-danger"></span>
                </div>

            </div>

            <div class="mb-3">
                <label asp-for="MeetingDescription" class="form-label"></label>

                <textarea asp-for="MeetingDescription"
                          class="form-control"
                          rows="3"
                          placeholder="Enter meeting description">
                </textarea>

                <span asp-validation-for="MeetingDescription" class="text-danger"></span>
            </div>

            <div class="d-flex gap-2">

                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-save"></i> Save
                </button>

                <a asp-action="MeetingsList" class="btn btn-secondary">
                    Cancel
                </a>
            </div>
        </form>
    </div>
</div>