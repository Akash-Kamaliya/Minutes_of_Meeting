@model MOM_Project.Models.MeetingsModel

<h2 class="h2 fw-bold">Edit Meeting</h2>

<div class="card shadow rounded-4 overflow-hidden">

    <div class="table-head px-3 py-2 bg-primary text-white">
        <div class="h5">Edit Meeting</div>
    </div>

    <div class="card-body">

        <form asp-action="MeetingsEditForm" method="post">

            <input type="hidden" asp-for="MeetingID" />

            <div class="row">

                <div class="col-md-6 mb-3">
                    <label class="form-label">Meeting Date</label>
                    <input asp-for="MeetingDate" type="datetime-local" class="form-control" />
                    <span asp-validation-for="MeetingDate" class="text-danger"></span>
                </div>

                <div class="col-md-6 mb-3">
                    <label class="form-label">Meeting Type</label>

                    <select asp-for="MeetingTypeID" class="form-control">
                        <option value="">Select Meeting Type</option>

                        @foreach (var item in ViewBag.MeetingTypeList)
                        {
                            <option value="@item.MeetingTypeID">
                                @item.MeetingTypeName
                            </option>
                        }
                    </select>

                    <span asp-validation-for="MeetingTypeID" class="text-danger"></span>
                </div>

            </div>


            <div class="row">

                <div class="col-md-6 mb-3">
                    <label class="form-label">Department</label>

                    <select asp-for="DepartmentID" class="form-control">
                        <option value="">Select Department</option>

                        @foreach (var item in ViewBag.DepartmentList)
                        {
                            <option value="@item.DepartmentID">
                                @item.DepartmentName
                            </option>
                        }
                    </select>
                </div>


                <div class="col-md-6 mb-3">
                    <label class="form-label">Meeting Venue</label>

                    <select asp-for="MeetingVenueID" class="form-control">
                        <option value="">Select Venue</option>

                        @foreach (var item in ViewBag.VenueList)
                        {
                            <option value="@item.MeetingVenueID">
                                @item.MeetingVenueName
                            </option>
                        }
                    </select>
                </div>

            </div>


            <div class="mb-3">
                <label class="form-label">Meeting Description</label>
                <textarea asp-for="MeetingDescription" class="form-control" rows="3"></textarea>
            </div>


            <button class="btn btn-primary">
                <i class="bi bi-pencil"></i> Update
            </button>

            <a asp-action="MeetingsList" class="btn btn-secondary">
                Cancel
            </a>

        </form>

    </div>
</div>